{
  "name": "dnd-hub-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "test:e2e": "playwright test",
    "test:e2e:system": "PLAYWRIGHT_EXECUTABLE_PATH=/usr/bin/chromium playwright test",
    "test:e2e:headed": "playwright test --headed",
    "typecheck": "node ./node_modules/typescript/bin/tsc -b"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "@playwright/test": "^1.54.0"
  }
}